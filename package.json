{
  "name": "baseline",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win"
