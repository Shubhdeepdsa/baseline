    "@tiptap/starter-kit": "^3.20.4",
    "@xenova/transformers": "^2.17.2",
    "docx": "^9.6.1",
    "electron-store": "^11.0.2",
    "fs": "^0.0.1-security",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.3",
    "electron": "^33.2.0",
    "electron-builder": "^26.8.1",
